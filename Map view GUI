import customtkinter
import tkintermapview
import re


class MapApp(customtkinter.CTk):
    def __init__(self):
        super().__init__()

        self.title("Modern Map Coordinate Marker")
        self.geometry("900x600")

        # --- Configure Grid Layout ---
        self.grid_columnconfigure(1, weight=1)
        self.grid_rowconfigure(0, weight=1)

        # --- Sidebar Frame ---
        self.sidebar = customtkinter.CTkFrame(self, width=200, corner_radius=0)
        self.sidebar.grid(row=0, column=0, sticky="nsew")

        self.label = customtkinter.CTkLabel(
            self.sidebar,
            text="Map Controls",
            font=customtkinter.CTkFont(size=20, weight="bold")
        )
        self.label.pack(pady=20, padx=10)

        # Entry for Coordinates
        self.coord_entry = customtkinter.CTkEntry(
            self.sidebar,
            placeholder_text="e.g. 19.0760° N, 72.8777° E"
        )
        self.coord_entry.pack(pady=10, padx=20)

        # Button
        self.button = customtkinter.CTkButton(
            self.sidebar,
            text="Add Marker",
            command=self.add_marker_event
        )
        self.button.pack(pady=10, padx=20)

        # Message Label
        self.message_label = customtkinter.CTkLabel(self.sidebar, text="")
        self.message_label.pack(pady=5)

        # --- Map Widget ---
        self.map_widget = tkintermapview.TkinterMapView(self, corner_radius=0)
        self.map_widget.grid(row=0, column=1, sticky="nsew")

        # Default position
        self.map_widget.set_position(20.0, 0.0)
        self.map_widget.set_zoom(2)

    def add_marker_event(self):
        raw_input = self.coord_entry.get().strip()

        if not raw_input:
            self.message_label.configure(text="Please enter coordinates!")
            return

        try:
            # Ensure comma
            if "," not in raw_input:
                raise ValueError("Missing comma")

            lat_part, lon_part = raw_input.split(",", 1)

            # Clean input using regex (handles ° and other symbols)
            lat_part = re.sub(r"[^0-9.\-NSEW]", "", lat_part.upper())
            lon_part = re.sub(r"[^0-9.\-NSEW]", "", lon_part.upper())

            # Latitude
            if "N" in lat_part:
                lat = float(lat_part.replace("N", ""))
            elif "S" in lat_part:
                lat = -float(lat_part.replace("S", ""))
            else:
                lat = float(lat_part)

            # Longitude
            if "E" in lon_part:
                lon = float(lon_part.replace("E", ""))
            elif "W" in lon_part:
                lon = -float(lon_part.replace("W", ""))
            else:
                lon = float(lon_part)

            # Validate range
            if not (-90 <= lat <= 90 and -180 <= lon <= 180):
                raise ValueError("Out of range")


            # Clear old markers
            self.map_widget.delete_all_marker()

            # Add marker
            self.map_widget.set_marker(lat, lon, text=f"{lat}, {lon}")

            # Focus map
            self.map_widget.set_position(lat, lon)
            self.map_widget.set_zoom(15)


        except Exception as e:
            print("Error:", e)


if __name__ == "__main__":
    app = MapApp()
    app.mainloop()